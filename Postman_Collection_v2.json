{
  "info": {
    "_postman_id": "360-sports-platform-v2",
    "name": "360 Sports Platform - Backend API v2",
    "description": "Complete API collection with Email Verification and Admin Registration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/v1/health/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication - Registration & Email Verification",
      "item": [
        {
          "name": "1️⃣ Register - Customer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"username\": \"john_customer\",\n  \"password\": \"SecurePass123\",\n  \"password2\": \"SecurePass123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"+91-9876543210\",\n  \"role\": \"customer\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/register/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "2️⃣ Send Verification Code",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/send-verification-code/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "send-verification-code"]
            }
          }
        },
        {
          "name": "3️⃣ Verify Email (With Code from Email)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/verify-email/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "verify-email"]
            }
          }
        },
        {
          "name": "Register - Business",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"business@example.com\",\n  \"username\": \"sports_arena\",\n  \"password\": \"SecurePass123\",\n  \"password2\": \"SecurePass123\",\n  \"first_name\": \"Sports\",\n  \"last_name\": \"Arena\",\n  \"phone\": \"+91-9876543211\",\n  \"role\": \"business\",\n  \"business_name\": \"Sports Arena Mumbai\",\n  \"business_description\": \"Premium multi-sport facility\",\n  \"business_registration_number\": \"REG123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/register/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication - Login & Admin",
      "item": [
        {
          "name": "Login - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"access_token\", jsonData.access);",
                  "pm.environment.set(\"refresh_token\", jsonData.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_customer\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/login/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Business",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"business_access_token\", jsonData.access);",
                  "pm.environment.set(\"business_refresh_token\", jsonData.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sports_arena\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/login/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Register Admin (Admin Only)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"username\": \"admin_user\",\n  \"password\": \"SecurePass123\",\n  \"password2\": \"SecurePass123\",\n  \"first_name\": \"Admin\",\n  \"last_name\": \"User\",\n  \"phone\": \"+91-9876543212\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/register/admin/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "register", "admin"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/v1/auth/token/refresh/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "v1", "auth", "token", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "User Profile Management",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
